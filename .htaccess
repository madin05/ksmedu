
ErrorDocument 404 404.html
ErrorDocument 500 500.html
ErrorDocument 505 505.html

# Block access to sensitive files and folders
<FilesMatch "^\.env|^\.git|^\.vscode|^\.gitignore|^README\.md">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to specific directories
RedirectMatch 404 /\.git
RedirectMatch 404 /\.vscode

# Prevent directory listing
Options -Indexes
